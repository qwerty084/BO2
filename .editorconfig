root = true

[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cs,xaml}]
indent_style = space
indent_size = 4

[*.{cpp,h}]
indent_style = space
indent_size = 4

[*.{yml,yaml,md}]
indent_style = space
indent_size = 2

[*.cs]
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false
csharp_style_namespace_declarations = block_scoped:silent
dotnet_diagnostic.IDE0060.severity = silent
dotnet_diagnostic.CA1822.severity = silent
dotnet_diagnostic.CA1859.severity = silent
dotnet_diagnostic.CA2101.severity = silent
dotnet_diagnostic.CsWinRT1028.severity = silent
dotnet_diagnostic.CsWinRT1030.severity = silent
dotnet_diagnostic.SYSLIB1054.severity = silent

[BO2.Tests/Fakes/*.cs]
dotnet_diagnostic.IDE0130.severity = silent

[BO2.Tests/**/*.cs]
dotnet_diagnostic.CA1707.severity = silent
