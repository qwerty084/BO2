  "readerRules": {
    "eventOrdering": [
      "Events is a ring containing snapshot.maxEventCount GameEventRecord slots.",
      "EventWriteIndex is the slot where the next event will be written.",
      "EventCount is the number of valid recent events and must be capped to MaxEventCount by readers.",
      "When EventCount is less than MaxEventCount, valid events are read from slot 0 through EventCount - 1.",
      "When EventCount is MaxEventCount, the ring has wrapped; the oldest event is at EventWriteIndex % MaxEventCount, and readers continue modulo MaxEventCount to decode events oldest-to-newest."
    ],
    "stableRead": [
      "WriteSequence is incremented before and after each native snapshot mutation.",
      "Odd WriteSequence values mean a write is in progress; even values mean no writer is in the write critical section.",
      "Readers must read WriteSequence, copy the full shared memory snapshot, then read WriteSequence again.",
      "A copied snapshot is stable only when the before and after WriteSequence values are equal and even.",
      "Readers must retry when the first WriteSequence value is odd or when the sequence changes during the copy; if all retry attempts fail, readers must refuse the snapshot."
    ]
  },
  "eventNameCompatibility": {
    "decision": [
      "For v6, GameEventRecord.EventType is authoritative when it contains a known non-Unknown GameEventType value.",
      "Managed readers may map known EventName values to GameEventType only when EventType decodes as Unknown.",
      "Unknown EventName values stay Unknown.",
      "Legacy-only EventName mappings are reader compatibility behavior for snapshots that publish Unknown event type with a known name; they are not native publishing requirements.",
      "When adding v7 or another future snapshot version to supportedVersions, keep this reader mapping for that version unless the new version policy explicitly removes or scopes it. If the mapping changes, gate the reader behavior by snapshot version and keep v6 behavior unchanged."
    ],
    "scope": [
      "This section records managed reader compatibility behavior. It does not define hook target discovery, hook probing order, candidate validation, MinHook behavior, polling fallback thresholds, stat address reads, or polling change filters.",
      "The gameEventType numeric values and current published EventName strings below describe shared-memory records only.",
      "The pollingFallbackPublishedNames list identifies EventName strings that polling fallback may publish; fallback sampling thresholds and stat-read behavior remain Event Monitor implementation details outside this contract."
    ],
