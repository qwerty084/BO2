<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="BO2.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BO2"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="BO2">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="24">
        <Border
            MaxWidth="420"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Padding="24"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="{ThemeResource OverlayCornerRadius}">
            <StackPanel Spacing="12">
                <TextBlock
                    Style="{ThemeResource SubtitleTextBlockStyle}"
                    Text="Player stats" />
                <TextBlock
                    Style="{ThemeResource DisplayTextBlockStyle}"
                    Text="{x:Bind ViewModel.PointsText, Mode=OneWay}" />
                <Grid
                    ColumnSpacing="24"
                    RowSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="0"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Kills" />
                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="1"
                        Style="{ThemeResource BodyStrongTextBlockStyle}"
                        Text="{x:Bind ViewModel.KillsText, Mode=OneWay}" />
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="0"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Downs" />
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="1"
                        Style="{ThemeResource BodyStrongTextBlockStyle}"
                        Text="{x:Bind ViewModel.DownsText, Mode=OneWay}" />
                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="0"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Revives" />
                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="1"
                        Style="{ThemeResource BodyStrongTextBlockStyle}"
                        Text="{x:Bind ViewModel.RevivesText, Mode=OneWay}" />
                    <TextBlock
                        Grid.Row="3"
                        Grid.Column="0"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Headshots" />
                    <TextBlock
                        Grid.Row="3"
                        Grid.Column="1"
                        Style="{ThemeResource BodyStrongTextBlockStyle}"
                        Text="{x:Bind ViewModel.HeadshotsText, Mode=OneWay}" />
                </Grid>
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
