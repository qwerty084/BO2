<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="BO2.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BO2"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="BO2">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <NavigationView
        x:Name="RootNavigationView"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="True"
        OpenPaneLength="320"
        PaneDisplayMode="Left"
        SelectionChanged="OnNavigationViewSelectionChanged">
        <NavigationView.MenuItems>
            <NavigationViewItem
                x:Name="HomeNavigationItem"
                Content="Home"
                Tag="home">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Home" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <NavigationView.PaneFooter>
            <StackPanel Padding="16,0,16,12">
                <StackPanel
                    Orientation="Horizontal"
                    Spacing="8">
                    <Grid
                        Width="8"
                        Height="8"
                        VerticalAlignment="Center">
                        <Ellipse
                            Fill="{ThemeResource SystemFillColorSuccessBrush}"
                            Visibility="{x:Bind ViewModel.ConnectedStatusVisibility, Mode=OneWay}" />
                        <Ellipse
                            Fill="{ThemeResource SystemFillColorCautionBrush}"
                            Visibility="{x:Bind ViewModel.UnsupportedStatusVisibility, Mode=OneWay}" />
                        <Ellipse
                            Fill="{ThemeResource SystemFillColorCriticalBrush}"
                            Visibility="{x:Bind ViewModel.DisconnectedStatusVisibility, Mode=OneWay}" />
                    </Grid>
                    <TextBlock
                        VerticalAlignment="Center"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </StackPanel>
        </NavigationView.PaneFooter>

        <ScrollViewer>
            <Grid Padding="32">
                <StackPanel Spacing="28">
                    <TextBlock
                        x:Name="PageTitle"
                        AutomationProperties.HeadingLevel="Level1"
                        Style="{ThemeResource TitleLargeTextBlockStyle}"
                        Text="Home" />

                    <StackPanel
                        x:Name="HomeContent"
                        Spacing="28">
                        <StackPanel Spacing="12">
                            <TextBlock
                                AutomationProperties.HeadingLevel="Level2"
                                Style="{ThemeResource SubtitleTextBlockStyle}"
                                Text="Timers" />
                            <Grid
                                ColumnSpacing="32"
                                RowSpacing="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="Game time" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Text="--:--:--" />
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="Round time" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Text="--:--" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Spacing="12">
                            <TextBlock
                                AutomationProperties.HeadingLevel="Level2"
                                Style="{ThemeResource SubtitleTextBlockStyle}"
                                Text="Player stats" />
                            <Grid
                                ColumnSpacing="32"
                                RowSpacing="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="Points" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Style="{ThemeResource BodyStrongTextBlockStyle}"
                                    Text="{x:Bind ViewModel.PointsText, Mode=OneWay}" />
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="Kills" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Style="{ThemeResource BodyStrongTextBlockStyle}"
                                    Text="{x:Bind ViewModel.KillsText, Mode=OneWay}" />
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="2"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="Downs" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    Style="{ThemeResource BodyStrongTextBlockStyle}"
                                    Text="{x:Bind ViewModel.DownsText, Mode=OneWay}" />
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="3"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="Revives" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="3"
                                    Style="{ThemeResource BodyStrongTextBlockStyle}"
                                    Text="{x:Bind ViewModel.RevivesText, Mode=OneWay}" />
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="4"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="Headshots" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="4"
                                    Style="{ThemeResource BodyStrongTextBlockStyle}"
                                    Text="{x:Bind ViewModel.HeadshotsText, Mode=OneWay}" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Spacing="12">
                            <TextBlock
                                AutomationProperties.HeadingLevel="Level2"
                                Style="{ThemeResource SubtitleTextBlockStyle}"
                                Text="Game events" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{x:Bind ViewModel.DetectedGameText, Mode=OneWay}" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel
                        x:Name="SettingsContent"
                        Spacing="12"
                        Visibility="Collapsed">
                        <TextBlock
                            AutomationProperties.HeadingLevel="Level2"
                            Style="{ThemeResource SubtitleTextBlockStyle}"
                            Text="Settings" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Settings will appear here." />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </NavigationView>
</Window>
