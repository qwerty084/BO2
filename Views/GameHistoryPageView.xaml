<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="BO2.Views.GameHistoryPageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:BO2.Views"
    mc:Ignorable="d">

    <UserControl.Resources>
        <views:BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <Grid RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <InfoBar
            IsClosable="False"
            IsOpen="True"
            Message="{Binding RecordingStatusText, Mode=OneWay}"
            Severity="Informational"
            Title="{Binding RecordingStatusTitle, Mode=OneWay}" />

        <Grid
            Grid.Row="1"
            RowSpacing="16"
            Visibility="{Binding IsListVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border
                Padding="18"
                Style="{StaticResource BO2CardBorderStyle}"
                Visibility="{Binding IsEmptyVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Spacing="8">
                    <TextBlock
                        AutomationProperties.HeadingLevel="Level2"
                        Style="{StaticResource BO2CardTitleTextBlockStyle}"
                        Text="{Binding EmptyStateTitle, Mode=OneWay}" />
                    <TextBlock
                        Style="{StaticResource BO2CaptionTextBlockStyle}"
                        Text="{Binding EmptyStateText, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <ListView
                x:Name="SavedGamesListView"
                Grid.Row="1"
                IsItemClickEnabled="True"
                ItemClick="OnSavedGameItemClick"
                ItemsSource="{Binding SavedGames, Mode=OneWay}"
                SelectionMode="None"
                Visibility="{Binding HasSavedGames, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,0,8" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource BO2CardBorderStyle}">
                            <Grid ColumnSpacing="18" RowSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Spacing="4">
                                    <TextBlock
                                        Style="{StaticResource BO2StatValueTextBlockStyle}"
                                        Text="{Binding MapNameText, Mode=OneWay}" />
                                    <TextBlock
                                        Style="{StaticResource BO2CaptionTextBlockStyle}"
                                        Text="{Binding DateText, Mode=OneWay}" />
                                </StackPanel>

                                <StackPanel
                                    Grid.Column="1"
                                    Spacing="4">
                                    <TextBlock
                                        x:Uid="GameHistoryFinalRoundLabel"
                                        Style="{StaticResource BO2CaptionTextBlockStyle}" />
                                    <TextBlock
                                        Style="{StaticResource BO2StatValueTextBlockStyle}"
                                        Text="{Binding FinalRoundText, Mode=OneWay}" />
                                </StackPanel>

                                <StackPanel
                                    Grid.Column="2"
                                    Spacing="4">
                                    <TextBlock
                                        x:Uid="GameHistoryDurationLabel"
                                        Style="{StaticResource BO2CaptionTextBlockStyle}" />
                                    <TextBlock
                                        Style="{StaticResource BO2StatValueTextBlockStyle}"
                                        Text="{Binding GameDurationText, Mode=OneWay}" />
                                </StackPanel>

                                <Grid
                                    Grid.Row="1"
                                    Grid.ColumnSpan="3"
                                    ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="3">
                                        <TextBlock x:Uid="PointsLabel" Style="{StaticResource BO2CaptionTextBlockStyle}" />
                                        <TextBlock Style="{StaticResource BO2StatValueTextBlockStyle}" Text="{Binding PointsText, Mode=OneWay}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="3">
                                        <TextBlock x:Uid="KillsLabel" Style="{StaticResource BO2CaptionTextBlockStyle}" />
                                        <TextBlock Style="{StaticResource BO2StatValueTextBlockStyle}" Text="{Binding KillsText, Mode=OneWay}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Spacing="3">
                                        <TextBlock x:Uid="HeadshotsLabel" Style="{StaticResource BO2CaptionTextBlockStyle}" />
                                        <TextBlock Style="{StaticResource BO2StatValueTextBlockStyle}" Text="{Binding HeadshotsText, Mode=OneWay}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" Spacing="3">
                                        <TextBlock x:Uid="DownsLabel" Style="{StaticResource BO2CaptionTextBlockStyle}" />
                                        <TextBlock Style="{StaticResource BO2StatValueTextBlockStyle}" Text="{Binding DownsText, Mode=OneWay}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="4" Spacing="3">
                                        <TextBlock x:Uid="RevivesLabel" Style="{StaticResource BO2CaptionTextBlockStyle}" />
                                        <TextBlock Style="{StaticResource BO2StatValueTextBlockStyle}" Text="{Binding RevivesText, Mode=OneWay}" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <Grid
            Grid.Row="1"
            RowSpacing="12"
            Visibility="{Binding IsDetailVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Button
                HorizontalAlignment="Left"
                Click="OnBackButtonClick"
                Style="{StaticResource BO2SecondaryButtonStyle}">
                <StackPanel
                    Orientation="Horizontal"
                    Spacing="8">
                    <FontIcon
                        FontSize="14"
                        Glyph="&#xE72B;" />
                    <TextBlock x:Uid="GameHistoryBackButtonText" />
                </StackPanel>
            </Button>

            <ListView
                Grid.Row="1"
                ItemsSource="{Binding SelectedGame.Rounds, Mode=OneWay}"
                SelectionMode="None">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,0,8" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.Header>
                    <StackPanel
                        Padding="0,0,0,12"
                        Spacing="12">
                        <Border Style="{StaticResource BO2CardBorderStyle}">
                            <StackPanel Spacing="14">
                                <Grid ColumnSpacing="18" RowSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Uid="GameHistoryDateLabel" Style="{StaticResource BO2CaptionTextBlockStyle}" />
                                        <TextBlock Style="{StaticResource BO2StatValueTextBlockStyle}" Text="{Binding SelectedGame.DateText, Mode=OneWay}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock x:Uid="GameHistoryMapLabel" Style="{StaticResource BO2CaptionTextBlockStyle}" />
                                        <TextBlock Style="{StaticResource BO2StatValueTextBlockStyle}" Text="{Binding SelectedGame.MapNameText, Mode=OneWay}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Spacing="4">
                                        <TextBlock x:Uid="GameHistoryFinalRoundLabel" Style="{StaticResource BO2CaptionTextBlockStyle}" />
                                        <TextBlock Style="{StaticResource BO2StatValueTextBlockStyle}" Text="{Binding SelectedGame.FinalRoundText, Mode=OneWay}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" Spacing="4">
                                        <TextBlock x:Uid="GameHistoryDurationLabel" Style="{StaticResource BO2CaptionTextBlockStyle}" />
                                        <TextBlock Style="{StaticResource BO2StatValueTextBlockStyle}" Text="{Binding SelectedGame.GameDurationText, Mode=OneWay}" />
                                    </StackPanel>
                                </Grid>

                                <TextBlock
                                    x:Uid="GameHistoryFinalStatsTitle"
                                    Style="{StaticResource BO2CardTitleTextBlockStyle}" />
                                <Grid ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="3">
                                        <TextBlock x:Uid="PointsLabel" Style="{StaticResource BO2CaptionTextBlockStyle}" />
                                        <TextBlock Style="{StaticResource BO2StatValueTextBlockStyle}" Text="{Binding SelectedGame.FinalStats.PointsText, Mode=OneWay}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="3">
                                        <TextBlock x:Uid="KillsLabel" Style="{StaticResource BO2CaptionTextBlockStyle}" />
                                        <TextBlock Style="{StaticResource BO2StatValueTextBlockStyle}" Text="{Binding SelectedGame.FinalStats.KillsText, Mode=OneWay}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Spacing="3">
                                        <TextBlock x:Uid="HeadshotsLabel" Style="{StaticResource BO2CaptionTextBlockStyle}" />
                                        <TextBlock Style="{StaticResource BO2StatValueTextBlockStyle}" Text="{Binding SelectedGame.FinalStats.HeadshotsText, Mode=OneWay}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" Spacing="3">
                                        <TextBlock x:Uid="DownsLabel" Style="{StaticResource BO2CaptionTextBlockStyle}" />
                                        <TextBlock Style="{StaticResource BO2StatValueTextBlockStyle}" Text="{Binding SelectedGame.FinalStats.DownsText, Mode=OneWay}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="4" Spacing="3">
                                        <TextBlock x:Uid="RevivesLabel" Style="{StaticResource BO2CaptionTextBlockStyle}" />
                                        <TextBlock Style="{StaticResource BO2StatValueTextBlockStyle}" Text="{Binding SelectedGame.FinalStats.RevivesText, Mode=OneWay}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <TextBlock
                            x:Uid="GameHistoryRoundsTitle"
                            AutomationProperties.HeadingLevel="Level2"
                            Style="{StaticResource BO2CardTitleTextBlockStyle}" />
                    </StackPanel>
                </ListView.Header>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource BO2CardBorderStyle}">
                            <StackPanel Spacing="12">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Style="{StaticResource BO2CardTitleTextBlockStyle}"
                                        Text="{Binding RoundTitleText, Mode=OneWay}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Style="{StaticResource BO2CaptionTextBlockStyle}"
                                        Text="{Binding DurationText, Mode=OneWay}" />
                                </Grid>

                                <Grid ColumnSpacing="20" RowSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Column="1" x:Uid="PointsLabel" Style="{StaticResource BO2CaptionTextBlockStyle}" />
                                    <TextBlock Grid.Column="2" x:Uid="KillsLabel" Style="{StaticResource BO2CaptionTextBlockStyle}" />
                                    <TextBlock Grid.Column="3" x:Uid="HeadshotsLabel" Style="{StaticResource BO2CaptionTextBlockStyle}" />
                                    <TextBlock Grid.Column="4" x:Uid="DownsLabel" Style="{StaticResource BO2CaptionTextBlockStyle}" />
                                    <TextBlock Grid.Column="5" x:Uid="RevivesLabel" Style="{StaticResource BO2CaptionTextBlockStyle}" />

                                    <TextBlock Grid.Row="1" x:Uid="GameHistoryCumulativeStatsLabel" Style="{StaticResource BO2CaptionTextBlockStyle}" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource BO2StatValueTextBlockStyle}" Text="{Binding CumulativeStats.PointsText, Mode=OneWay}" />
                                    <TextBlock Grid.Row="1" Grid.Column="2" Style="{StaticResource BO2StatValueTextBlockStyle}" Text="{Binding CumulativeStats.KillsText, Mode=OneWay}" />
                                    <TextBlock Grid.Row="1" Grid.Column="3" Style="{StaticResource BO2StatValueTextBlockStyle}" Text="{Binding CumulativeStats.HeadshotsText, Mode=OneWay}" />
                                    <TextBlock Grid.Row="1" Grid.Column="4" Style="{StaticResource BO2StatValueTextBlockStyle}" Text="{Binding CumulativeStats.DownsText, Mode=OneWay}" />
                                    <TextBlock Grid.Row="1" Grid.Column="5" Style="{StaticResource BO2StatValueTextBlockStyle}" Text="{Binding CumulativeStats.RevivesText, Mode=OneWay}" />

                                    <TextBlock Grid.Row="2" x:Uid="GameHistoryDeltaStatsLabel" Style="{StaticResource BO2CaptionTextBlockStyle}" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource BO2StatValueTextBlockStyle}" Text="{Binding DeltaStats.PointsText, Mode=OneWay}" />
                                    <TextBlock Grid.Row="2" Grid.Column="2" Style="{StaticResource BO2StatValueTextBlockStyle}" Text="{Binding DeltaStats.KillsText, Mode=OneWay}" />
                                    <TextBlock Grid.Row="2" Grid.Column="3" Style="{StaticResource BO2StatValueTextBlockStyle}" Text="{Binding DeltaStats.HeadshotsText, Mode=OneWay}" />
                                    <TextBlock Grid.Row="2" Grid.Column="4" Style="{StaticResource BO2StatValueTextBlockStyle}" Text="{Binding DeltaStats.DownsText, Mode=OneWay}" />
                                    <TextBlock Grid.Row="2" Grid.Column="5" Style="{StaticResource BO2StatValueTextBlockStyle}" Text="{Binding DeltaStats.RevivesText, Mode=OneWay}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.Footer>
                    <Border
                        Margin="0,4,0,0"
                        Style="{StaticResource BO2CardBorderStyle}">
                        <StackPanel Spacing="12">
                            <StackPanel Spacing="4">
                                <TextBlock
                                    x:Uid="GameHistoryBoxEventsTitle"
                                    AutomationProperties.HeadingLevel="Level2"
                                    Style="{StaticResource BO2CardTitleTextBlockStyle}" />
                                <TextBlock
                                    x:Uid="GameHistoryBoxEventsDescription"
                                    Style="{StaticResource BO2CaptionTextBlockStyle}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <TextBlock
                                Style="{StaticResource BO2CaptionTextBlockStyle}"
                                Text="{Binding SelectedGame.BoxEventsEmptyText, Mode=OneWay}"
                                Visibility="{Binding SelectedGame.IsBoxEventsEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                            <ItemsControl
                                ItemsSource="{Binding SelectedGame.BoxEvents, Mode=OneWay}"
                                Visibility="{Binding SelectedGame.HasBoxEvents, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Margin="0,0,0,8"
                                            Padding="12"
                                            Background="{ThemeResource BO2Surface2Brush}"
                                            CornerRadius="8">
                                            <StackPanel Spacing="8">
                                                <TextBlock
                                                    Style="{StaticResource BO2StatValueTextBlockStyle}"
                                                    Text="{Binding PrimaryText, Mode=OneWay}"
                                                    TextWrapping="WrapWholeWords" />
                                                <Grid ColumnSpacing="18" RowSpacing="6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <TextBlock x:Uid="GameHistoryBoxEventReceivedLabel" Style="{StaticResource BO2CaptionTextBlockStyle}" />
                                                    <TextBlock Grid.Column="1" Style="{StaticResource BO2BodyTextBlockStyle}" Text="{Binding ReceivedAtText, Mode=OneWay}" />
                                                    <TextBlock Grid.Row="1" x:Uid="GameHistoryBoxEventEventLabel" Style="{StaticResource BO2CaptionTextBlockStyle}" />
                                                    <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource BO2BodyTextBlockStyle}" Text="{Binding EventNameText, Mode=OneWay}" />
                                                    <TextBlock Grid.Row="2" x:Uid="GameHistoryBoxEventRawWeaponLabel" Style="{StaticResource BO2CaptionTextBlockStyle}" />
                                                    <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource BO2BodyTextBlockStyle}" Text="{Binding RawWeaponTokenText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                                    <TextBlock Grid.Row="3" x:Uid="GameHistoryBoxEventStringValueLabel" Style="{StaticResource BO2CaptionTextBlockStyle}" />
                                                    <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource BO2BodyTextBlockStyle}" Text="{Binding StringValueText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </ListView.Footer>
            </ListView>
        </Grid>
    </Grid>
</UserControl>
